# LootLocker global-leaderboard config. Copy this file to `.env` and fill in.
# Create a game + a leaderboard in the LootLocker dashboard to get these.
# When these are absent the global leaderboard disables gracefully and the
# game runs fully offline (local Hall of High Scores only).

# Game API key (dev_... or prod_...). Public client key — safe to ship in bundle.
VITE_LOOTLOCKER_GAME_KEY=
# The leaderboard's key (set when you create the leaderboard).
VITE_LOOTLOCKER_LEADERBOARD_KEY=
# Any version string; sent with the guest session.
VITE_LOOTLOCKER_GAME_VERSION=0.1.0
